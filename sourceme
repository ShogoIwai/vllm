export OPENAI_BASE_URL=http://localhost:8000/v1
export OPENAI_API_KEY=dummy

# Configure sgpt to use local vLLM server
_sgptrc="${HOME}/.config/shell_gpt/.sgptrc"
if [ -f "${_sgptrc}" ]; then
    sed -i 's|^API_BASE_URL=.*|API_BASE_URL=http://localhost:8000/v1|' "${_sgptrc}"
    sed -i 's|^DEFAULT_MODEL=.*|DEFAULT_MODEL=local-model-qwen3-coder-30b-a3b-awq|' "${_sgptrc}"
fi
unset _sgptrc
